<% if video_learnings.any? %>
  <div id="project_videos" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% video_learnings.each do |vl| %>
      <div class="relative bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow group">
        <!-- Remove button -->
        <div class="absolute top-2 right-2 z-10">
          <%= button_to remove_video_project_path(project, video_learning_id: vl.id), method: :delete, class: "inline-flex items-center justify-center w-7 h-7 rounded-full bg-white/90 text-gray-500 hover:bg-red-50 hover:text-red-600 shadow-sm opacity-0 group-hover:opacity-100 transition-all border border-gray-200", title: "Remove from project" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          <% end %>
        </div>

        <%= link_to video_learning_path(vl), class: "block" do %>
          <% if vl.thumbnail_url.present? %>
            <div class="aspect-video bg-gray-100">
              <img src="<%= vl.thumbnail_url %>" alt="<%= vl.title %>" class="w-full h-full object-cover" loading="lazy">
            </div>
          <% else %>
            <div class="aspect-video bg-gray-100 flex items-center justify-center">
              <svg class="w-12 h-12 text-gray-300" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/><path fill="white" d="M9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </div>
          <% end %>
          <div class="p-4">
            <h3 class="text-sm font-semibold text-gray-900 line-clamp-2"><%= vl.title || "Processing..." %></h3>
            <% if vl.channel_name.present? %>
              <p class="mt-1 text-xs text-gray-500"><%= vl.channel_name %></p>
            <% end %>
            <div class="mt-2 flex items-center justify-between">
              <% case vl.status %>
              <% when "completed" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Completed</span>
              <% when "failed" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">Failed</span>
              <% when "pending" %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">Pending</span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800">Processing</span>
              <% end %>
              <% if vl.formatted_duration %>
                <span class="text-xs text-gray-500"><%= vl.formatted_duration %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% else %>
  <div id="project_videos">
    <div class="text-center py-8 bg-white rounded-lg border border-gray-200">
      <svg class="mx-auto h-10 w-10 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
      </svg>
      <h3 class="mt-2 text-sm font-medium text-gray-900">No videos in this project</h3>
      <p class="mt-1 text-sm text-gray-500">Add completed videos using the form below.</p>
    </div>
  </div>
<% end %>
