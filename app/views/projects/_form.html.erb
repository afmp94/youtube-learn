<%= form_with model: project, class: "space-y-6" do |f| %>
  <% if project.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <ul class="text-sm text-red-700 list-disc list-inside">
        <% project.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_field :name, required: true, autofocus: true,
        placeholder: "e.g., AI Content Strategy, Leadership Research",
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-3 py-2 border" %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :description, rows: 2,
        placeholder: "A short description of this project...",
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-3 py-2 border" %>
  </div>

  <div>
    <%= f.label :brief, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :brief, rows: 4,
        placeholder: "What's this project about? This guides AI content generation...",
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-3 py-2 border" %>
    <p class="mt-1 text-xs text-gray-500">This brief will be used to guide AI when generating content for this project.</p>
  </div>

  <div>
    <%= f.label :color, class: "block text-sm font-medium text-gray-700" %>
    <%= f.select :color,
        [["Indigo", "indigo"], ["Emerald", "emerald"], ["Amber", "amber"], ["Rose", "rose"], ["Sky", "sky"], ["Purple", "purple"], ["Orange", "orange"]],
        { prompt: "Choose a color..." },
        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-3 py-2 border" %>
  </div>

  <div class="flex items-center justify-end space-x-3">
    <% if project.persisted? %>
      <%= link_to "Cancel", project_path(project), class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
    <% else %>
      <%= link_to "Cancel", projects_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
    <% end %>
    <%= f.submit project.persisted? ? "Update Project" : "Create Project",
        class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 cursor-pointer" %>
  </div>
<% end %>
