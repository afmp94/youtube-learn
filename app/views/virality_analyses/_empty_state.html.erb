<div style="background: linear-gradient(180deg, #08080f 0%, #0d0d18 100%); border: 1px solid #1a1a2e;"
     class="rounded-2xl p-8 flex flex-col items-center justify-center min-h-[520px] relative overflow-hidden">
  <!-- Ghosted radar background -->
  <svg viewBox="0 0 400 400" class="w-64 h-64 opacity-30 mb-6">
    <% 3.times do |ring| %>
      <% radius = (ring + 1) * 50 %>
      <polygon points="<%= 8.times.map { |i| angle = i * Math::PI * 2 / 8 - Math::PI / 2; "#{200 + radius * Math.cos(angle)},#{200 + radius * Math.sin(angle)}" }.join(' ') %>"
               fill="none" stroke="#1e1e2e" stroke-width="0.5"/>
    <% end %>
    <% 8.times do |i| %>
      <% angle = i * Math::PI * 2 / 8 - Math::PI / 2 %>
      <line x1="200" y1="200"
            x2="<%= 200 + 150 * Math.cos(angle) %>" y2="<%= 200 + 150 * Math.sin(angle) %>"
            stroke="#1e1e2e" stroke-width="0.5"/>
    <% end %>
  </svg>

  <div class="text-center space-y-3">
    <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto" style="background: rgba(129,140,248,0.1); border: 1px solid rgba(129,140,248,0.15);">
      <svg class="w-7 h-7" style="color: #818cf8;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
      </svg>
    </div>
    <h3 class="text-lg font-bold" style="color: #e2e2ef;">Ready to Analyze</h3>
    <p class="text-sm max-w-xs" style="color: #5a5a6e;">
      Submit content, a video, or a strategy to see which virality dimensions light up.
    </p>
  </div>
</div>
