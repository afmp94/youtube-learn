<div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow" data-controller="quote-copy">
  <div class="p-6">
    <!-- Decorative quote mark -->
    <div class="mb-3">
      <svg class="w-8 h-8 text-indigo-300" fill="currentColor" viewBox="0 0 24 24">
        <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983z"/>
      </svg>
    </div>

    <!-- Quote text -->
    <p class="text-gray-800 text-lg leading-relaxed font-serif italic" data-quote-copy-target="text"><%= quote.text %></p>

    <!-- Attribution -->
    <div class="mt-4 flex items-center text-sm text-gray-500">
      <span class="font-medium text-gray-700">&mdash; <%= quote.speaker || "Unknown" %></span>
      <% if quote.video_learning.present? %>
        <span class="mx-2">&middot;</span>
        <%= link_to quote.video_learning.title, video_learning_path(quote.video_learning),
              class: "text-indigo-600 hover:text-indigo-800 truncate max-w-xs", title: quote.video_learning.title %>
      <% end %>
    </div>

    <!-- Context -->
    <% if quote.context.present? %>
      <p class="mt-3 text-sm text-gray-400 italic"><%= quote.context %></p>
    <% end %>

    <!-- Bottom actions -->
    <div class="mt-4 pt-4 border-t border-gray-100 flex items-center justify-between">
      <div class="flex items-center space-x-3">
        <% if quote.youtube_timestamp_url.present? %>
          <%= link_to quote.youtube_timestamp_url, target: "_blank", rel: "noopener",
                class: "inline-flex items-center text-xs font-medium text-gray-500 hover:text-indigo-600 transition-colors" do %>
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <%= quote.formatted_timestamp %>
          <% end %>
        <% end %>
        <button type="button" data-action="quote-copy#copy"
                class="inline-flex items-center text-xs font-medium text-gray-500 hover:text-indigo-600 transition-colors">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          Copy
        </button>
      </div>
      <% if quote.video_learning.present? %>
        <%= link_to new_content_piece_path(video_learning_ids: [quote.video_learning.id]),
              class: "inline-flex items-center text-xs font-medium text-indigo-600 hover:text-indigo-800 transition-colors" do %>
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          Use in Content
        <% end %>
      <% end %>
    </div>
  </div>
</div>
