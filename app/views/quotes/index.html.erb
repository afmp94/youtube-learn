<div class="space-y-6">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Quotes</h1>
      <p class="mt-1 text-sm text-gray-500">Notable quotes extracted from your video library</p>
    </div>
    <div class="flex items-center space-x-3">
      <!-- Search -->
      <%= form_tag search_quotes_path, method: :get, class: "flex items-center" do %>
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <input type="text" name="q" value="<%= params[:q] %>" placeholder="Search quotes..."
                 class="pl-10 pr-4 py-2 border border-gray-300 rounded-md text-sm focus:ring-indigo-500 focus:border-indigo-500 w-64">
        </div>
      <% end %>
    </div>
  </div>

  <!-- Filters -->
  <% if @speakers.present? %>
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-sm font-medium text-gray-500">Filter by speaker:</span>
      <%= link_to "All", quotes_path,
            class: "inline-flex items-center px-3 py-1 rounded-full text-xs font-medium transition-colors #{params[:speaker].blank? ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
      <% @speakers.each do |speaker| %>
        <%= link_to speaker, quotes_path(speaker: speaker),
              class: "inline-flex items-center px-3 py-1 rounded-full text-xs font-medium transition-colors #{params[:speaker] == speaker ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" %>
      <% end %>
    </div>
  <% end %>

  <!-- Search indicator -->
  <% if params[:q].present? %>
    <div class="flex items-center justify-between bg-indigo-50 rounded-lg px-4 py-3">
      <p class="text-sm text-indigo-700">
        Showing results for "<strong><%= params[:q] %></strong>"
        <% if @quotes.respond_to?(:count) %>
          &mdash; <%= @pagy&.count || 0 %> found
        <% end %>
      </p>
      <%= link_to "Clear", quotes_path, class: "text-sm font-medium text-indigo-600 hover:text-indigo-800" %>
    </div>
  <% end %>

  <!-- Quotes Grid -->
  <% if @quotes.present? && @quotes.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @quotes.each do |quote| %>
        <%= render "quotes/quote_card", quote: quote %>
      <% end %>
    </div>

    <!-- Pagination -->
    <% if @pagy && @pagy.pages > 1 %>
      <nav class="flex justify-center mt-8">
        <%== pagy_nav(@pagy) %>
      </nav>
    <% end %>
  <% else %>
    <!-- Empty state -->
    <div class="text-center py-16 bg-white rounded-lg border border-gray-200">
      <svg class="mx-auto h-16 w-16 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"/>
      </svg>
      <h3 class="mt-4 text-lg font-medium text-gray-900">No quotes extracted yet</h3>
      <p class="mt-2 text-sm text-gray-500 max-w-md mx-auto">
        Quotes are automatically extracted from your video transcripts. Process some videos to see memorable quotes appear here.
      </p>
      <%= link_to new_video_learning_path, class: "mt-6 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        Add a Video
      <% end %>
    </div>
  <% end %>
</div>
