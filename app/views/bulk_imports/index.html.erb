<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Imports</h1>
    <%= link_to new_bulk_import_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Import
    <% end %>
  </div>

  <% if @bulk_imports.any? %>
    <div class="space-y-4">
      <% @bulk_imports.each do |import| %>
        <%= link_to bulk_import_path(import), class: "block bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow" do %>
          <div class="p-5">
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center space-x-3">
                <h3 class="text-base font-semibold text-gray-900 truncate">
                  <%= import.title.presence || truncate(import.source_url, length: 60) %>
                </h3>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                  <%= import.playlist? ? 'bg-purple-100 text-purple-700' : 'bg-blue-100 text-blue-700' %>">
                  <%= import.playlist? ? 'Playlist' : 'Channel' %>
                </span>
              </div>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                <%= case import.status
                    when 'pending' then 'bg-gray-100 text-gray-700'
                    when 'extracting_urls' then 'bg-yellow-100 text-yellow-700'
                    when 'processing' then 'bg-blue-100 text-blue-700'
                    when 'completed' then 'bg-green-100 text-green-700'
                    when 'failed' then 'bg-red-100 text-red-700'
                    end %>">
                <%= case import.status
                    when 'pending' then 'Pending'
                    when 'extracting_urls' then 'Discovering'
                    when 'processing' then 'Processing'
                    when 'completed' then 'Completed'
                    when 'failed' then 'Failed'
                    end %>
              </span>
            </div>

            <% if import.total_count > 0 %>
              <div class="mb-3">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-sm text-gray-600"><%= import.processed_count %> / <%= import.total_count %> videos</span>
                  <span class="text-sm text-gray-500"><%= import.progress_percentage %>%</span>
                </div>
                <div class="w-full bg-gray-200 rounded-full h-2">
                  <div class="bg-indigo-600 h-2 rounded-full transition-all duration-500" style="width: <%= import.progress_percentage %>%"></div>
                </div>
              </div>
            <% end %>

            <div class="flex items-center text-xs text-gray-500 space-x-4">
              <span><%= time_ago_in_words(import.created_at) %> ago</span>
              <span class="truncate max-w-xs"><%= import.source_url %></span>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 bg-white rounded-lg border border-gray-200">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
      </svg>
      <h3 class="mt-3 text-sm font-semibold text-gray-900">No imports yet</h3>
      <p class="mt-1 text-sm text-gray-500">Import a YouTube playlist to get started.</p>
      <div class="mt-6">
        <%= link_to new_bulk_import_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          New Import
        <% end %>
      </div>
    </div>
  <% end %>
</div>
