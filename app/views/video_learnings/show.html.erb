<%= turbo_stream_from "video_learning_#{@video_learning.id}" %>

<div class="space-y-8">
  <!-- Hero Header -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-0">
      <% if @video_learning.youtube_embed_url %>
        <div class="lg:col-span-3 bg-black">
          <div class="aspect-video">
            <iframe src="<%= @video_learning.youtube_embed_url %>" class="w-full h-full" frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen></iframe>
          </div>
        </div>
      <% end %>
      <div class="lg:col-span-2 p-6 flex flex-col justify-between">
        <div>
          <h1 class="text-xl font-bold text-gray-900 leading-tight"><%= @video_learning.title || "Processing video..." %></h1>
          <% if @video_learning.channel_name.present? %>
            <p class="mt-2 text-sm text-gray-500 flex items-center">
              <svg class="w-4 h-4 mr-1.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              <%= @video_learning.channel_name %>
            </p>
          <% end %>
          <div class="mt-4 flex flex-wrap gap-2">
            <% if @video_learning.formatted_duration %>
              <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium bg-gray-100 text-gray-700">
                <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <%= @video_learning.formatted_duration %>
              </span>
            <% end %>
            <% if @video_learning.difficulty_level.present? %>
              <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium
                <%= case @video_learning.difficulty_level
                    when 'beginner' then 'bg-green-100 text-green-700'
                    when 'intermediate' then 'bg-yellow-100 text-yellow-700'
                    when 'advanced' then 'bg-red-100 text-red-700'
                    else 'bg-gray-100 text-gray-700'
                    end %>">
                <%= @video_learning.difficulty_level.capitalize %>
              </span>
            <% end %>
            <% if @video_learning.estimated_read_time.present? %>
              <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium bg-blue-50 text-blue-700">
                <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                ~<%= @video_learning.estimated_read_time %> min read
              </span>
            <% end %>
          </div>
        </div>
        <div class="mt-6 flex flex-wrap gap-2">
          <% if @video_learning.completed? %>
            <%= link_to markdown_export_path(@video_learning), class: "inline-flex items-center px-3 py-2 border border-gray-200 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition-colors" do %>
              <svg class="w-4 h-4 mr-1.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              Markdown
            <% end %>
            <%= link_to pdf_export_path(@video_learning), class: "inline-flex items-center px-3 py-2 border border-gray-200 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition-colors" do %>
              <svg class="w-4 h-4 mr-1.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
              PDF
            <% end %>
          <% end %>
          <% if @video_learning.failed? %>
            <%= button_to "Retry", reprocess_video_learning_path(@video_learning), method: :post, class: "inline-flex items-center px-3 py-2 border border-transparent text-sm font-medium rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 transition-colors" %>
          <% end %>
          <%= link_to video_learnings_path, class: "inline-flex items-center px-3 py-2 border border-gray-200 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition-colors" do %>
            <svg class="w-4 h-4 mr-1.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            All Videos
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Progress bar -->
  <div id="progress_bar">
    <%= render "video_learnings/progress_bar", video_learning: @video_learning, message: nil %>
  </div>

  <!-- Content -->
  <div id="video_learning_content">
    <%= render "video_learnings/content", video_learning: @video_learning %>
  </div>
</div>
