<% unless video_learning.completed? %>
  <% if video_learning.failed? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <div class="flex items-center">
        <svg class="w-5 h-5 text-red-400 mr-2" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
        <p class="text-sm text-red-700"><%= video_learning.error_message || "Processing failed" %></p>
      </div>
    </div>
  <% else %>
    <div class="bg-white border border-gray-200 rounded-lg p-4" data-controller="progress">
      <div class="flex items-center justify-between mb-2">
        <p class="text-sm font-medium text-gray-700"><%= message || status_label(video_learning) %></p>
        <span class="text-sm text-gray-500"><%= video_learning.processing_progress %>%</span>
      </div>
      <div class="w-full bg-gray-200 rounded-full h-2">
        <div class="bg-indigo-600 h-2 rounded-full transition-all duration-500" style="width: <%= video_learning.processing_progress %>%"></div>
      </div>
    </div>
  <% end %>
<% end %>
