<% if video_learning.completed? %>
  <div class="space-y-8">
    <!-- Summary -->
    <div class="bg-gradient-to-br from-indigo-50 to-white rounded-2xl border border-indigo-100 p-8">
      <div class="flex items-center mb-4">
        <div class="w-8 h-8 rounded-lg bg-indigo-100 flex items-center justify-center mr-3">
          <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </div>
        <h2 class="text-lg font-bold text-gray-900">Summary</h2>
      </div>
      <div class="text-gray-700 leading-relaxed space-y-3">
        <%= simple_format(video_learning.summary) %>
      </div>
    </div>

    <!-- Key Takeaways -->
    <% if video_learning.key_takeaways.present? %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
        <div class="flex items-center mb-6">
          <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center mr-3">
            <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          </div>
          <h2 class="text-lg font-bold text-gray-900">Key Takeaways</h2>
          <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600"><%= video_learning.key_takeaways.length %></span>
        </div>
        <div class="space-y-4">
          <% video_learning.key_takeaways.each_with_index do |takeaway, i| %>
            <div class="flex items-start group">
              <span class="flex-shrink-0 w-7 h-7 rounded-full bg-emerald-100 text-emerald-700 text-xs font-bold flex items-center justify-center mr-4 mt-0.5 group-hover:bg-emerald-200 transition-colors">
                <%= i + 1 %>
              </span>
              <p class="text-gray-700 leading-relaxed"><%= takeaway %></p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Concepts -->
    <% if video_learning.concepts.present? %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
        <div class="flex items-center mb-6">
          <div class="w-8 h-8 rounded-lg bg-purple-100 flex items-center justify-center mr-3">
            <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
          </div>
          <h2 class="text-lg font-bold text-gray-900">Concepts Covered</h2>
          <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600"><%= video_learning.concepts.length %></span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <% video_learning.concepts.each do |concept| %>
            <div class="group rounded-xl border border-gray-100 p-5 hover:border-purple-200 hover:shadow-sm transition-all bg-gray-50/50 hover:bg-purple-50/30">
              <div class="flex items-start justify-between mb-2">
                <h3 class="text-sm font-bold text-gray-900 leading-snug"><%= concept["name"] %></h3>
                <% if concept["importance"] %>
                  <span class="ml-2 flex-shrink-0 w-2 h-2 rounded-full mt-1.5
                    <%= case concept['importance']
                        when 'high' then 'bg-red-400'
                        when 'medium' then 'bg-yellow-400'
                        else 'bg-gray-300'
                        end %>">
                  </span>
                <% end %>
              </div>
              <p class="text-sm text-gray-600 leading-relaxed"><%= concept["description"] %></p>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Detailed Notes -->
    <% if video_learning.detailed_notes.present? %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8" data-controller="clipboard">
        <div class="flex items-center justify-between mb-6">
          <div class="flex items-center">
            <div class="w-8 h-8 rounded-lg bg-amber-100 flex items-center justify-center mr-3">
              <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            </div>
            <h2 class="text-lg font-bold text-gray-900">Detailed Notes</h2>
          </div>
          <button data-action="click->clipboard#copy" data-clipboard-target="source" data-content="<%= video_learning.detailed_notes %>"
            class="inline-flex items-center px-3 py-1.5 border border-gray-200 text-xs font-medium rounded-lg text-gray-600 bg-white hover:bg-gray-50 transition-colors">
            <svg class="w-3.5 h-3.5 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
            Copy Markdown
          </button>
        </div>
        <div class="prose prose-sm max-w-none text-gray-700">
          <%= render_markdown(video_learning.detailed_notes) %>
        </div>
      </div>
    <% end %>

    <!-- Frame Gallery -->
    <% if video_learning.frames.any? %>
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
        <div class="flex items-center mb-6">
          <div class="w-8 h-8 rounded-lg bg-sky-100 flex items-center justify-center mr-3">
            <svg class="w-4 h-4 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <h2 class="text-lg font-bold text-gray-900">Video Frames</h2>
          <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600"><%= video_learning.frames.count %></span>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
          <% video_learning.frames.ordered.each do |frame| %>
            <% if frame.image.attached? %>
              <div class="relative group rounded-xl overflow-hidden bg-gray-100">
                <%= image_tag frame.image, class: "w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-200", loading: "lazy" %>
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                <div class="absolute bottom-0 left-0 right-0 px-2 py-1.5">
                  <span class="text-white text-xs font-medium bg-black/50 px-1.5 py-0.5 rounded"><%= frame.formatted_timestamp %></span>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Tags -->
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8" data-controller="tag-input">
      <div class="flex items-center mb-4">
        <div class="w-8 h-8 rounded-lg bg-gray-100 flex items-center justify-center mr-3">
          <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
        </div>
        <h2 class="text-lg font-bold text-gray-900">Tags</h2>
      </div>
      <div class="flex flex-wrap gap-2 mb-4">
        <% video_learning.tags.each do |tag| %>
          <span class="inline-flex items-center pl-3 pr-1.5 py-1.5 rounded-lg text-sm font-medium bg-indigo-50 text-indigo-700 border border-indigo-100">
            <%= tag.name %>
            <%= button_to video_learning_tag_path(video_learning, tag), method: :delete, class: "ml-1.5 p-0.5 rounded hover:bg-indigo-100 text-indigo-400 hover:text-indigo-600 transition-colors" do %>
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            <% end %>
          </span>
        <% end %>
      </div>
      <%= form_with url: video_learning_tags_path(video_learning), method: :post, class: "flex items-center gap-2" do |f| %>
        <%= f.text_field :name, placeholder: "Add a tag...", class: "flex-1 rounded-lg border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm px-3 py-2 border", data: { tag_input_target: "input" } %>
        <%= f.submit "Add", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 cursor-pointer transition-colors" %>
      <% end %>
    </div>
  </div>
<% elsif video_learning.failed? %>
  <!-- Shown in progress bar already -->
<% else %>
  <div class="text-center py-16 text-gray-400">
    <svg class="mx-auto w-12 h-12 mb-4 animate-spin text-indigo-500" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/></svg>
    <p class="text-sm font-medium text-gray-500">Video is being processed...</p>
    <p class="text-xs text-gray-400 mt-1">This page will update automatically.</p>
  </div>
<% end %>
