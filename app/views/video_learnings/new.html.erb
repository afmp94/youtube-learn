<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Submit a YouTube Video</h1>

  <div class="bg-white shadow-sm rounded-lg border border-gray-200 p-6" data-controller="url-input">
    <%= form_with model: @video_learning, url: video_learnings_path, class: "space-y-6" do |f| %>
      <% if @video_learning.errors.any? %>
        <div class="rounded-md bg-red-50 p-4">
          <ul class="text-sm text-red-700 list-disc list-inside">
            <% @video_learning.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :youtube_url, "YouTube URL", class: "block text-sm font-medium text-gray-700" %>
        <%= f.url_field :youtube_url, required: true, autofocus: true,
            placeholder: "https://www.youtube.com/watch?v=...",
            data: { url_input_target: "input", action: "input->url-input#validate" },
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-3 py-2 border" %>
        <p class="mt-1 text-xs text-gray-500" data-url-input-target="hint">Paste a YouTube video URL to analyze</p>
      </div>

      <!-- Thumbnail preview -->
      <div data-url-input-target="preview" class="hidden">
        <div class="aspect-video rounded-lg overflow-hidden bg-gray-100">
          <img data-url-input-target="thumbnail" class="w-full h-full object-cover" alt="Video thumbnail">
        </div>
      </div>

      <%= f.submit "Analyze Video", data: { url_input_target: "submit" },
          class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed" %>
    <% end %>
  </div>
</div>
