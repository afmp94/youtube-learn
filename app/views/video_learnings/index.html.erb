<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Videos</h1>
    <div class="flex items-center space-x-3">
      <%= link_to "Search", search_video_learnings_path, class: "inline-flex items-center px-3 py-1.5 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
      <%= link_to new_video_learning_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
        New Video
      <% end %>
    </div>
  </div>

  <!-- Filters -->
  <div class="flex items-center space-x-2">
    <%= link_to "All", video_learnings_path, class: "px-3 py-1 rounded-full text-sm font-medium #{params[:status].blank? && params[:tag].blank? ? 'bg-indigo-100 text-indigo-700' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}" %>
    <%= link_to "Completed", video_learnings_path(status: :completed), class: "px-3 py-1 rounded-full text-sm font-medium #{params[:status] == 'completed' ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}" %>
    <%= link_to "Processing", video_learnings_path(status: :extracting), class: "px-3 py-1 rounded-full text-sm font-medium #{params[:status] == 'extracting' ? 'bg-yellow-100 text-yellow-700' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}" %>
    <%= link_to "Failed", video_learnings_path(status: :failed), class: "px-3 py-1 rounded-full text-sm font-medium #{params[:status] == 'failed' ? 'bg-red-100 text-red-700' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}" %>
  </div>

  <% if @video_learnings.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @video_learnings.each do |vl| %>
        <%= render "video_learnings/card", video_learning: vl %>
      <% end %>
    </div>

    <div class="mt-6">
      <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white rounded-lg border border-gray-200">
      <p class="text-sm text-gray-500">No videos found.</p>
    </div>
  <% end %>
</div>
