<% content_for(:title) { "Chat - YouTube Learn" } %>

<div class="max-w-6xl mx-auto">
  <!-- Header -->
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Chat with Your Knowledge Base</h1>
      <p class="mt-1 text-sm text-gray-500">Ask questions across all your video learnings and get AI-powered answers with citations.</p>
    </div>
    <%= link_to new_conversation_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 shadow-sm transition-colors" do %>
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      New Chat
    <% end %>
  </div>

  <% if @conversations.any? %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Conversations List -->
      <div class="lg:col-span-1 space-y-2">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-3">Your Chats</h2>
        <div id="conversations_list" class="space-y-2">
          <% @conversations.each do |conversation| %>
            <%= render "conversations/sidebar_item", conversation: conversation, active: false %>
          <% end %>
        </div>
      </div>

      <!-- Empty State for Right Panel -->
      <div class="lg:col-span-2 flex items-center justify-center">
        <div class="text-center py-16">
          <div class="mx-auto w-16 h-16 bg-indigo-50 rounded-full flex items-center justify-center mb-4">
            <svg class="w-8 h-8 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          </div>
          <h3 class="text-lg font-medium text-gray-900 mb-1">Select a conversation</h3>
          <p class="text-sm text-gray-500 mb-6">Choose from your existing chats or start a new one.</p>
          <%= link_to new_conversation_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 transition-colors" do %>
            <svg class="w-4 h-4 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Start a new chat
          <% end %>
        </div>
      </div>
    </div>
  <% else %>
    <!-- No Conversations Empty State -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 py-16 text-center">
      <div class="mx-auto w-20 h-20 bg-gradient-to-br from-indigo-50 to-purple-50 rounded-full flex items-center justify-center mb-6">
        <svg class="w-10 h-10 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
      </div>
      <h2 class="text-xl font-semibold text-gray-900 mb-2">Chat with your knowledge base</h2>
      <p class="text-gray-500 mb-8 max-w-md mx-auto">Ask questions about anything you've learned from your videos. Get AI-powered answers with citations to specific videos.</p>
      <% if Current.user.video_learnings.completed.any? %>
        <%= link_to new_conversation_path, class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 shadow-sm transition-colors" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Start your first chat
        <% end %>
      <% else %>
        <p class="text-sm text-gray-400 mb-4">You need at least one processed video to start chatting.</p>
        <%= link_to new_video_learning_path, class: "inline-flex items-center px-6 py-3 border border-transparent text-base font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 shadow-sm transition-colors" do %>
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Add your first video
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
