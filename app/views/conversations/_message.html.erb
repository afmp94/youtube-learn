<div id="message_<%= message.id %>" class="mb-4">
  <% if message.user? %>
    <!-- User Message -->
    <div class="flex justify-end">
      <div class="max-w-[80%]">
        <div class="px-4 py-3 bg-indigo-600 text-white rounded-2xl rounded-br-md">
          <div class="text-sm leading-relaxed whitespace-pre-wrap"><%= message.content %></div>
        </div>
        <div class="text-right mt-1">
          <span class="text-xs text-gray-400"><%= message.created_at.strftime("%-I:%M %p") %></span>
        </div>
      </div>
    </div>
  <% else %>
    <!-- Assistant Message -->
    <div class="flex justify-start">
      <div class="max-w-[80%]">
        <div class="flex items-start space-x-3">
          <div class="shrink-0 w-8 h-8 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-lg flex items-center justify-center mt-1">
            <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          </div>
          <div class="flex-1">
            <div class="px-4 py-3 bg-white border border-gray-200 rounded-2xl rounded-bl-md shadow-sm">
              <div class="prose prose-sm max-w-none text-gray-800 leading-relaxed">
                <%= render_markdown(message.content) %>
              </div>
            </div>

            <% if message.has_sources? %>
              <details class="mt-2 ml-1">
                <summary class="text-xs text-gray-400 hover:text-indigo-500 cursor-pointer select-none transition-colors">
                  <svg class="w-3 h-3 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
                  Sources (<%= message.source_videos.count %>)
                </summary>
                <div class="mt-1.5 flex flex-wrap gap-1.5">
                  <% message.source_videos.each do |video| %>
                    <%= link_to video_learning_path(video), class: "inline-flex items-center px-2.5 py-1 rounded-md text-xs font-medium bg-indigo-50 text-indigo-700 hover:bg-indigo-100 transition-colors" do %>
                      <svg class="w-3 h-3 mr-1 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                      <span class="truncate max-w-[200px]"><%= video.title %></span>
                    <% end %>
                  <% end %>
                </div>
              </details>
            <% end %>

            <div class="mt-1 ml-1">
              <span class="text-xs text-gray-400"><%= message.created_at.strftime("%-I:%M %p") %></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
