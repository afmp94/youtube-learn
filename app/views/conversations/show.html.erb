<% content_for(:title) { "#{@conversation.title} - Chat - YouTube Learn" } %>

<%= turbo_stream_from "conversation_#{@conversation.id}" %>

<div class="max-w-4xl mx-auto" data-controller="chat" data-chat-conversation-id-value="<%= @conversation.id %>">
  <!-- Chat Header -->
  <div class="bg-white rounded-t-lg shadow-sm border border-gray-200 px-6 py-4 flex items-center justify-between">
    <div class="flex items-center space-x-4">
      <%= link_to conversations_path, class: "text-gray-400 hover:text-gray-600 transition-colors" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      <% end %>
      <div>
        <h1 class="text-lg font-semibold text-gray-900 truncate max-w-md" id="conversation_title"><%= @conversation.title %></h1>
        <p class="text-xs text-gray-400"><%= @conversation.message_count %> messages</p>
      </div>
    </div>
    <div class="flex items-center space-x-2">
      <%= link_to new_conversation_path, class: "p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors", title: "New Chat" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      <% end %>
      <%= button_to conversation_path(@conversation), method: :delete, class: "p-2 text-gray-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors", title: "Delete conversation", data: { turbo_confirm: "Delete this conversation?" } do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
      <% end %>
    </div>
  </div>

  <!-- Messages Area -->
  <div class="bg-gray-50 border-l border-r border-gray-200 overflow-y-auto" style="height: calc(100vh - 320px); min-height: 400px;" data-chat-target="messages" id="messages_container">
    <div class="px-6 py-4 space-y-1" id="messages">
      <% if @messages.empty? %>
        <div class="flex items-center justify-center h-full py-16" id="empty_state">
          <div class="text-center">
            <div class="mx-auto w-12 h-12 bg-indigo-50 rounded-full flex items-center justify-center mb-3">
              <svg class="w-6 h-6 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
            </div>
            <p class="text-sm text-gray-500">Ask a question about your video learnings...</p>
          </div>
        </div>
      <% else %>
        <% @messages.each do |message| %>
          <%= render "conversations/message", message: message %>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Input Area -->
  <div class="bg-white rounded-b-lg shadow-sm border border-gray-200 px-6 py-4">
    <div id="chat_input_form">
      <%= render "conversations/input_form", conversation: @conversation %>
    </div>
  </div>
</div>
