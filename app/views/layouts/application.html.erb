<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "YouTube Learn" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="YouTube Learn">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full">
    <% if authenticated? %>
      <nav class="bg-white shadow-sm border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16">
            <div class="flex items-center space-x-8">
              <%= link_to root_path, class: "flex items-center space-x-2 text-indigo-600 font-bold text-xl" do %>
                <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                <span>YouTube Learn</span>
              <% end %>
              <div class="hidden md:flex items-center space-x-4">
                <%= link_to "Dashboard", root_path, class: "text-gray-600 hover:text-gray-900 px-3 py-2 text-sm font-medium" %>
                <%= link_to "Videos", video_learnings_path, class: "text-gray-600 hover:text-gray-900 px-3 py-2 text-sm font-medium" %>
                <%= link_to "Experts", channels_path, class: "text-gray-600 hover:text-gray-900 px-3 py-2 text-sm font-medium" %>
                <%= link_to "Projects", projects_path, class: "text-gray-600 hover:text-gray-900 px-3 py-2 text-sm font-medium" %>
                <%= link_to "Imports", bulk_imports_path, class: "text-gray-600 hover:text-gray-900 px-3 py-2 text-sm font-medium" %>
                <%= link_to "Content", content_pieces_path, class: "text-gray-600 hover:text-gray-900 px-3 py-2 text-sm font-medium" %>
                <%= link_to "Lab", virality_analyses_path, class: "text-gray-600 hover:text-gray-900 px-3 py-2 text-sm font-medium" %>
                <%= link_to "Quotes", quotes_path, class: "text-gray-600 hover:text-gray-900 px-3 py-2 text-sm font-medium" %>
                <%= link_to "Chat", conversations_path, class: "text-gray-600 hover:text-gray-900 px-3 py-2 text-sm font-medium" %>
              </div>
            </div>
            <div class="flex items-center space-x-4">
              <%= link_to "New Video", new_video_learning_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
              <span class="text-sm text-gray-500"><%= Current.user.email_address %></span>
              <%= button_to "Sign out", session_path, method: :delete, class: "text-sm text-gray-500 hover:text-gray-700" %>
            </div>
          </div>
        </div>
      </nav>
    <% end %>

    <% if flash[:notice] %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
        <div class="rounded-md bg-green-50 p-4">
          <p class="text-sm text-green-700"><%= flash[:notice] %></p>
        </div>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
        <div class="rounded-md bg-red-50 p-4">
          <p class="text-sm text-red-700"><%= flash[:alert] %></p>
        </div>
      </div>
    <% end %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>
  </body>
</html>
