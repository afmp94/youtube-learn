<div class="space-y-6">
  <div class="flex items-center space-x-3">
    <%= link_to "Tags", tags_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    <span class="text-gray-400">/</span>
    <h1 class="text-2xl font-bold text-gray-900"><%= @tag.name %></h1>
  </div>

  <% if @video_learnings.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @video_learnings.each do |vl| %>
        <%= render "video_learnings/card", video_learning: vl %>
      <% end %>
    </div>
    <div class="mt-6">
      <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white rounded-lg border border-gray-200">
      <p class="text-sm text-gray-500">No videos with this tag.</p>
    </div>
  <% end %>
</div>
