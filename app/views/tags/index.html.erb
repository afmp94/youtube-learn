<div class="space-y-6">
  <h1 class="text-2xl font-bold text-gray-900">Tags</h1>

  <% if @tags.any? %>
    <div class="flex flex-wrap gap-3">
      <% @tags.each do |tag| %>
        <%= link_to tag_path(tag.name), class: "inline-flex items-center px-4 py-2 rounded-full text-sm font-medium bg-white border border-gray-200 text-gray-700 hover:bg-indigo-50 hover:border-indigo-200 hover:text-indigo-700 transition-colors" do %>
          <%= tag.name %>
          <span class="ml-2 bg-gray-100 text-gray-500 rounded-full px-2 py-0.5 text-xs"><%= tag.video_learnings.count %></span>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12 bg-white rounded-lg border border-gray-200">
      <p class="text-sm text-gray-500">No tags yet. Tags are automatically created when videos are analyzed.</p>
    </div>
  <% end %>
</div>
