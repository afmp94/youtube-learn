<%
  platform_colors = {
    "linkedin" => "bg-blue-50 text-blue-700",
    "twitter" => "bg-sky-50 text-sky-700",
    "youtube_script" => "bg-red-50 text-red-700",
    "blog" => "bg-purple-50 text-purple-700",
    "newsletter" => "bg-amber-50 text-amber-700"
  }

  format_labels = {
    "post" => "Post",
    "thread" => "Thread",
    "script" => "Script",
    "carousel_outline" => "Carousel",
    "article" => "Article",
    "hooks_list" => "Hooks"
  }
%>

<div class="max-w-4xl mx-auto space-y-6">
  <!-- Breadcrumb -->
  <nav class="flex items-center space-x-2 text-sm text-gray-500">
    <%= link_to "Content", content_pieces_path, class: "hover:text-gray-700" %>
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
    <%= link_to(@content_piece.title.presence || @content_piece.platform_label, content_piece_path(@content_piece), class: "hover:text-gray-700") %>
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
    <span class="text-gray-900 font-medium">Edit</span>
  </nav>

  <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-xl font-bold text-gray-900">Edit Content</h1>
      <div class="flex items-center gap-2">
        <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium <%= platform_colors[@content_piece.platform] %>">
          <%= @content_piece.platform_label %>
        </span>
        <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium bg-gray-100 text-gray-600">
          <%= format_labels[@content_piece.content_format] || @content_piece.content_format.titleize %>
        </span>
      </div>
    </div>

    <%= form_with model: @content_piece, class: "space-y-6" do |f| %>
      <% if @content_piece.errors.any? %>
        <div class="rounded-md bg-red-50 p-4">
          <ul class="text-sm text-red-700 list-disc list-inside">
            <% @content_piece.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :title, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_field :title, placeholder: "Content title (optional)",
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-3 py-2 border" %>
      </div>

      <div>
        <%= f.label :body, class: "block text-sm font-medium text-gray-700" %>
        <%= f.text_area :body, rows: 20, placeholder: "Write your content here...",
            class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-3 py-2 border font-mono" %>
        <p class="mt-1 text-xs text-gray-500">
          <% if @content_piece.platform.in?(%w[blog newsletter]) %>
            Markdown formatting is supported for blog and newsletter content.
          <% else %>
            Write plain text content for <%= @content_piece.platform_label %>.
          <% end %>
        </p>
      </div>

      <div class="flex items-center justify-between pt-4 border-t border-gray-100">
        <div class="text-sm text-gray-500">
          <span id="word-count-display"><%= @content_piece.word_count %> words</span>
        </div>
        <div class="flex items-center gap-3">
          <%= link_to "Cancel", content_piece_path(@content_piece),
              class: "inline-flex items-center px-4 py-2 border border-gray-200 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition-colors" %>
          <%= f.submit "Save Changes",
              class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 cursor-pointer transition-colors" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
