<%= turbo_stream_from "user_#{Current.user.id}_content" %>

<%
  platform_colors = {
    "linkedin" => "bg-blue-50 text-blue-700",
    "twitter" => "bg-sky-50 text-sky-700",
    "youtube_script" => "bg-red-50 text-red-700",
    "blog" => "bg-purple-50 text-purple-700",
    "newsletter" => "bg-amber-50 text-amber-700"
  }

  format_labels = {
    "post" => "Post",
    "thread" => "Thread",
    "script" => "Script",
    "carousel_outline" => "Carousel",
    "article" => "Article",
    "hooks_list" => "Hooks"
  }

  render_as_markdown = @content_piece.platform.in?(%w[blog newsletter])
%>

<div class="space-y-6">
  <!-- Breadcrumb -->
  <nav class="flex items-center space-x-2 text-sm text-gray-500">
    <%= link_to "Content", content_pieces_path, class: "hover:text-gray-700" %>
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
    <span class="text-gray-900 font-medium"><%= @content_piece.title.presence || @content_piece.platform_label %></span>
  </nav>

  <!-- Header Card -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
      <div class="flex-1">
        <h1 class="text-xl font-bold text-gray-900 leading-tight">
          <%= @content_piece.title.presence || "#{@content_piece.platform_label} #{format_labels[@content_piece.content_format]}" %>
        </h1>
        <div class="mt-3 flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium <%= platform_colors[@content_piece.platform] %>">
            <%= @content_piece.platform_label %>
          </span>
          <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium bg-gray-100 text-gray-600">
            <%= format_labels[@content_piece.content_format] || @content_piece.content_format.titleize %>
          </span>
          <%= render "content_pieces/status_badge", content_piece: @content_piece %>
          <% if @content_piece.template_name.present? %>
            <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium bg-indigo-50 text-indigo-600">
              <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg>
              <%= @content_piece.template_name %>
            </span>
          <% end %>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="flex flex-wrap items-center gap-2">
        <%= link_to edit_content_piece_path(@content_piece), class: "inline-flex items-center px-3 py-2 border border-gray-200 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition-colors" do %>
          <svg class="w-4 h-4 mr-1.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          Edit
        <% end %>

        <button data-controller="clipboard-content" data-clipboard-content-body-value="<%= @content_piece.body %>" data-action="click->clipboard-content#copy"
          class="inline-flex items-center px-3 py-2 border border-gray-200 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition-colors">
          <svg class="w-4 h-4 mr-1.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          <span data-clipboard-content-target="label">Copy</span>
        </button>

        <%= button_to virality_analyses_path(input_type: "content_piece", content_piece_id: @content_piece.id), method: :post, class: "inline-flex items-center px-3 py-2 border border-indigo-200 text-sm font-medium rounded-lg text-indigo-700 bg-indigo-50 hover:bg-indigo-100 transition-colors" do %>
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          Analyze Virality
        <% end %>

        <%= button_to regenerate_content_piece_path(@content_piece), method: :post, class: "inline-flex items-center px-3 py-2 border border-gray-200 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition-colors" do %>
          <svg class="w-4 h-4 mr-1.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          Regenerate
        <% end %>

        <%= button_to content_piece_path(@content_piece), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this content piece?" }, class: "inline-flex items-center px-3 py-2 border border-red-200 text-sm font-medium rounded-lg text-red-600 bg-white hover:bg-red-50 transition-colors" do %>
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          Delete
        <% end %>
      </div>
    </div>

    <!-- Status Update Buttons -->
    <div class="mt-4 pt-4 border-t border-gray-100" data-controller="status-update">
      <span class="text-xs font-medium text-gray-500 uppercase tracking-wide mr-3">Move to:</span>
      <% %w[draft review published].each do |status| %>
        <% next if @content_piece.status == status %>
        <button data-action="click->status-update#update"
                data-status-update-url-value="<%= update_status_content_piece_path(@content_piece) %>"
                data-status="<%= status %>"
                class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium
                  <%= case status
                      when 'draft' then 'bg-gray-50 text-gray-600 hover:bg-gray-100 border border-gray-200'
                      when 'review' then 'bg-yellow-50 text-yellow-700 hover:bg-yellow-100 border border-yellow-200'
                      when 'published' then 'bg-green-50 text-green-700 hover:bg-green-100 border border-green-200'
                      end %> transition-colors cursor-pointer">
          <%= status.capitalize %>
        </button>
      <% end %>
    </div>
  </div>

  <!-- Generation Status (updated via Turbo Streams) -->
  <div id="content_generation_status"></div>

  <!-- Content Body -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center">
        <div class="w-8 h-8 rounded-lg bg-indigo-100 flex items-center justify-center mr-3">
          <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </div>
        <h2 class="text-lg font-bold text-gray-900">Content</h2>
        <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600"><%= @content_piece.word_count %> words</span>
      </div>
    </div>

    <div class="prose prose-sm max-w-none text-gray-700" id="content_body">
      <% if render_as_markdown %>
        <%= render_markdown(@content_piece.body) %>
      <% else %>
        <%= simple_format(@content_piece.body) %>
      <% end %>
    </div>
  </div>

  <!-- Source Videos -->
  <% if @content_piece.video_learnings.any? %>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
      <div class="flex items-center mb-6">
        <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center mr-3">
          <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        </div>
        <h2 class="text-lg font-bold text-gray-900">Generated From</h2>
        <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600"><%= @content_piece.video_learnings.size %></span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @content_piece.video_learnings.each do |vl| %>
          <%= link_to video_learning_path(vl), class: "flex items-center gap-3 p-3 rounded-lg border border-gray-100 hover:border-gray-200 hover:bg-gray-50 transition-all group" do %>
            <% if vl.thumbnail_url.present? %>
              <div class="flex-shrink-0 w-20 h-12 rounded-md overflow-hidden bg-gray-100">
                <img src="<%= vl.thumbnail_url %>" alt="<%= vl.title %>" class="w-full h-full object-cover group-hover:scale-105 transition-transform" loading="lazy">
              </div>
            <% else %>
              <div class="flex-shrink-0 w-20 h-12 rounded-md bg-gray-100 flex items-center justify-center">
                <svg class="w-6 h-6 text-gray-300" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/><path fill="white" d="M9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              </div>
            <% end %>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-gray-900 truncate"><%= vl.title || "Untitled video" %></p>
              <% if vl.channel_name.present? %>
                <p class="text-xs text-gray-500 truncate"><%= vl.channel_name %></p>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Collection Link -->
  <% if @content_piece.collection.present? %>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
      <div class="flex items-center">
        <div class="w-8 h-8 rounded-lg bg-purple-100 flex items-center justify-center mr-3">
          <svg class="w-4 h-4 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
        </div>
        <div>
          <p class="text-xs text-gray-500">From collection</p>
          <%= link_to @content_piece.collection.name, collection_path(@content_piece.collection), class: "text-sm font-medium text-indigo-600 hover:text-indigo-700" %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Metadata -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
    <div class="flex flex-wrap gap-x-8 gap-y-3 text-sm text-gray-500">
      <div>
        <span class="font-medium text-gray-700">Created:</span>
        <%= @content_piece.created_at.strftime("%B %d, %Y at %l:%M %p") %>
      </div>
      <% if @content_piece.updated_at != @content_piece.created_at %>
        <div>
          <span class="font-medium text-gray-700">Updated:</span>
          <%= @content_piece.updated_at.strftime("%B %d, %Y at %l:%M %p") %>
        </div>
      <% end %>
      <div>
        <span class="font-medium text-gray-700">Word count:</span>
        <%= @content_piece.word_count %>
      </div>
      <% if @content_piece.template_name.present? %>
        <div>
          <span class="font-medium text-gray-700">Template:</span>
          <%= @content_piece.template_name %>
        </div>
      <% end %>
    </div>
  </div>
</div>
