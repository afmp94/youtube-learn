<div class="max-w-2xl mx-auto py-8">
  <!-- Header -->
  <div class="text-center mb-10">
    <h1 class="text-3xl font-bold text-gray-900">What do you want to share?</h1>
    <p class="mt-2 text-gray-500">Tell me your idea and I'll turn your knowledge into content</p>
  </div>

  <%= form_with url: generate_content_pieces_path, method: :post, class: "space-y-6", data: { controller: "smart-content", action: "submit->smart-content#submit" } do |f| %>

    <% if @projects.any? %>
      <div class="flex justify-center mb-2">
        <select name="project_id" class="rounded-xl border-gray-200 text-sm py-2 px-4 text-gray-600 focus:border-indigo-500 focus:ring-indigo-500">
          <option value="">All Knowledge Base</option>
          <% @projects.each do |project| %>
            <option value="<%= project.id %>" <%= "selected" if @selected_project == project %>>
              <%= project.name %>
            </option>
          <% end %>
        </select>
      </div>
    <% end %>

    <!-- Platform Pills -->
    <div class="flex justify-center">
      <div class="inline-flex items-center bg-gray-100 rounded-xl p-1 gap-1" data-smart-content-target="platformGroup">
        <button type="button" data-action="click->smart-content#selectPlatform" data-platform="linkedin"
          class="platform-pill px-4 py-2 rounded-lg text-sm font-medium transition-all bg-white shadow-sm text-blue-700">
          <svg class="w-4 h-4 inline-block mr-1 -mt-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </button>

        <button type="button" data-action="click->smart-content#selectPlatform" data-platform="twitter"
          class="platform-pill px-4 py-2 rounded-lg text-sm font-medium transition-all text-gray-500 hover:text-gray-700">
          <svg class="w-4 h-4 inline-block mr-1 -mt-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          Twitter
        </button>

        <button type="button" data-action="click->smart-content#selectPlatform" data-platform="youtube_script"
          class="platform-pill px-4 py-2 rounded-lg text-sm font-medium transition-all text-gray-500 hover:text-gray-700">
          <svg class="w-4 h-4 inline-block mr-1 -mt-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          YouTube
        </button>

        <button type="button" data-action="click->smart-content#selectPlatform" data-platform="blog"
          class="platform-pill px-4 py-2 rounded-lg text-sm font-medium transition-all text-gray-500 hover:text-gray-700">
          <svg class="w-4 h-4 inline-block mr-1 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
          Blog
        </button>

        <button type="button" data-action="click->smart-content#selectPlatform" data-platform="newsletter"
          class="platform-pill px-4 py-2 rounded-lg text-sm font-medium transition-all text-gray-500 hover:text-gray-700">
          <svg class="w-4 h-4 inline-block mr-1 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          Newsletter
        </button>
      </div>
    </div>

    <input type="hidden" name="platform" value="linkedin" data-smart-content-target="platformField">

    <!-- The Main Input -->
    <div class="relative">
      <textarea
        name="prompt"
        rows="5"
        data-smart-content-target="prompt"
        data-action="input->smart-content#updateButton"
        placeholder="e.g. I learned something incredible about pricing strategy today from Alex Hormozi. The idea that you should raise your prices and then make the offer so good people feel stupid saying no..."
        class="block w-full rounded-2xl border-gray-200 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-lg p-6 resize-none placeholder:text-gray-300"
        autofocus
      ></textarea>
      <div class="absolute bottom-4 right-4 text-xs text-gray-300" data-smart-content-target="charCount">0 chars</div>
    </div>

    <!-- Knowledge indicator -->
    <% if @video_count > 0 %>
      <div class="flex items-center justify-center gap-2 text-sm text-gray-400">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
        <% if @selected_project %>
          Drawing from project <strong class="text-gray-600"><%= @selected_project.name %></strong> knowledge base
        <% else %>
          Drawing from <strong class="text-gray-600"><%= @video_count %> videos</strong> in your knowledge base
        <% end %>
      </div>
    <% end %>

    <!-- Submit -->
    <div class="flex justify-center">
      <button type="submit" disabled
        data-smart-content-target="submitButton"
        class="inline-flex items-center px-8 py-3.5 border border-transparent text-base font-semibold rounded-xl text-white bg-indigo-600 hover:bg-indigo-700 disabled:opacity-40 disabled:cursor-not-allowed transition-all shadow-sm hover:shadow-md">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        Create Content
      </button>
    </div>
  <% end %>

  <!-- Suggestions -->
  <div class="mt-12 border-t border-gray-100 pt-8">
    <p class="text-center text-xs font-medium text-gray-400 uppercase tracking-wider mb-5">Try something like</p>
    <div class="grid grid-cols-1 gap-3" data-controller="suggestion-click">
      <% suggestions = [] %>

      <% if @top_channels.any? %>
        <% suggestions << "I've been studying #{@top_channels.first}'s ideas and here's the thing that blew my mind..." %>
        <% suggestions << "Top #{[@top_channels.size, 3].min} lessons I learned from #{@top_channels.first(3).join(', ')}" %>
      <% end %>

      <% if @top_tags.any? %>
        <% suggestions << "Everything I've learned about #{@top_tags.first} — distilled into one post" %>
        <% suggestions << "A thread breaking down #{@top_tags.first} for people who are just getting started" %>
      <% end %>

      <% if suggestions.empty? %>
        <% suggestions = [
          "I learned something today that completely changed how I think about business...",
          "Thread: 5 ideas that sound wrong but are actually genius",
          "Here's a framework I picked up that I wish I knew years ago",
          "The best advice I've heard this week, and why most people ignore it"
        ] %>
      <% end %>

      <% suggestions.first(4).each do |suggestion| %>
        <button type="button"
          data-action="click->suggestion-click#fill"
          data-text="<%= suggestion %>"
          class="text-left p-4 rounded-xl border border-gray-100 hover:border-indigo-200 hover:bg-indigo-50/30 transition-all text-sm text-gray-500 hover:text-gray-700 cursor-pointer">
          "<%= suggestion %>"
        </button>
      <% end %>
    </div>
  </div>
</div>
