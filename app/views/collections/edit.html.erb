<div class="max-w-2xl mx-auto">
  <div class="flex items-center space-x-3 mb-6">
    <%= link_to "Collections", collections_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    <span class="text-gray-400">/</span>
    <%= link_to @collection.name, collection_path(@collection), class: "text-sm text-gray-500 hover:text-gray-700" %>
    <span class="text-gray-400">/</span>
    <span class="text-sm text-gray-900 font-medium">Edit</span>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-6">Edit Collection</h1>

  <div class="bg-white shadow-sm rounded-lg border border-gray-200 p-6">
    <%= render "collections/form", collection: @collection %>
  </div>
</div>
