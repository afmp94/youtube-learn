<div class="space-y-8">
  <!-- Breadcrumb -->
  <div class="flex items-center space-x-3">
    <%= link_to "Collections", collections_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    <span class="text-gray-400">/</span>
    <span class="text-sm text-gray-900 font-medium"><%= @collection.name %></span>
  </div>

  <!-- Header -->
  <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
    <div class="flex items-start justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900"><%= @collection.name %></h1>
        <% if @collection.description.present? %>
          <p class="mt-2 text-sm text-gray-600"><%= @collection.description %></p>
        <% end %>
      </div>
      <div class="flex items-center space-x-2">
        <% if @collection.video_learnings.completed.any? %>
          <%= link_to new_content_piece_path(collection_id: @collection.id), class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" do %>
            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            Generate Content
          <% end %>
        <% end %>
        <%= link_to edit_collection_path(@collection), class: "inline-flex items-center px-3 py-2 border border-gray-200 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition-colors" do %>
          <svg class="w-4 h-4 mr-1.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
          Edit
        <% end %>
        <%= button_to collection_path(@collection), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this collection?" }, class: "inline-flex items-center px-3 py-2 border border-red-200 text-sm font-medium rounded-lg text-red-700 bg-white hover:bg-red-50 transition-colors" do %>
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          Delete
        <% end %>
      </div>
    </div>

    <!-- Stats -->
    <div id="collection_stats">
      <%= render "collections/stats", collection: @collection %>
    </div>
  </div>

  <!-- Videos Section -->
  <div>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900">Videos</h2>
      <span class="text-sm text-gray-500"><%= @video_learnings.size %> <%= "video".pluralize(@video_learnings.size) %></span>
    </div>

    <%= render "collections/video_grid", video_learnings: @video_learnings, collection: @collection %>
  </div>

  <!-- Add Videos Section -->
  <div id="add_video_form">
    <%= render "collections/add_video_form", collection: @collection, available_videos: @available_videos %>
  </div>

  <!-- Content Pieces Section -->
  <% if @content_pieces.any? %>
    <div>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900">Generated Content</h2>
        <span class="text-sm text-gray-500"><%= @content_pieces.size %> <%= "piece".pluralize(@content_pieces.size) %></span>
      </div>

      <div class="space-y-3">
        <% @content_pieces.each do |piece| %>
          <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4 hover:shadow-md transition-shadow">
            <div class="flex items-center justify-between">
              <div class="flex items-center space-x-3">
                <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium bg-indigo-100 text-indigo-700">
                  <%= piece.platform_label %>
                </span>
                <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium bg-gray-100 text-gray-700">
                  <%= piece.content_format.humanize %>
                </span>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
                  <%= case piece.status_color
                      when 'gray' then 'bg-gray-100 text-gray-800'
                      when 'yellow' then 'bg-yellow-100 text-yellow-800'
                      when 'green' then 'bg-green-100 text-green-800'
                      end %>">
                  <%= piece.status.capitalize %>
                </span>
              </div>
              <div class="flex items-center space-x-3">
                <span class="text-xs text-gray-500"><%= piece.word_count %> words</span>
                <%= link_to "View", content_piece_path(piece), class: "text-sm text-indigo-600 hover:text-indigo-500" %>
              </div>
            </div>
            <% if piece.body.present? %>
              <p class="mt-2 text-sm text-gray-600 line-clamp-2"><%= truncate(piece.body, length: 200) %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
