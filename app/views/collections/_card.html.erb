<%= link_to collection_path(collection), class: "block bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow" do %>
  <!-- Thumbnail strip -->
  <div class="h-32 bg-gray-100 flex">
    <% thumbnails = collection.video_learnings.where.not(thumbnail_url: [nil, ""]).limit(4) %>
    <% if thumbnails.any? %>
      <% thumbnails.each do |vl| %>
        <div class="flex-1 min-w-0">
          <img src="<%= vl.thumbnail_url %>" alt="" class="w-full h-full object-cover" loading="lazy">
        </div>
      <% end %>
      <% if thumbnails.size < 4 %>
        <% (4 - thumbnails.size).times do %>
          <div class="flex-1 min-w-0 bg-gray-100 flex items-center justify-center">
            <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <div class="w-full flex items-center justify-center">
        <svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
      </div>
    <% end %>
  </div>

  <div class="p-4">
    <h3 class="text-sm font-semibold text-gray-900 line-clamp-1"><%= collection.name %></h3>
    <% if collection.description.present? %>
      <p class="mt-1 text-xs text-gray-500 line-clamp-2"><%= collection.description %></p>
    <% end %>
    <div class="mt-3 flex items-center justify-between">
      <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium bg-indigo-100 text-indigo-700">
        <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        <%= collection.video_count %> <%= "video".pluralize(collection.video_count) %>
      </span>
      <% if collection.content_pieces.any? %>
        <span class="text-xs text-gray-500"><%= collection.content_pieces.count %> content</span>
      <% end %>
    </div>
  </div>
<% end %>
