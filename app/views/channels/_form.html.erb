<%= form_with model: channel, class: "space-y-6" do |f| %>
  <% if channel.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <ul class="text-sm text-red-700 list-disc list-inside">
        <% channel.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :description, "Description", class: "block text-sm font-medium text-gray-700" %>
    <p class="mt-1 text-xs text-gray-500">A brief description of what this expert covers.</p>
    <%= f.text_area :description, rows: 3,
        placeholder: "e.g., AI researcher focused on large language models and reasoning...",
        class: "mt-2 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-3 py-2 border" %>
  </div>

  <div>
    <%= f.label :notes, "Personal Notes", class: "block text-sm font-medium text-gray-700" %>
    <p class="mt-1 text-xs text-gray-500">Your private notes about this expert. Only you can see these.</p>
    <%= f.text_area :notes, rows: 5,
        placeholder: "Your personal notes about this expert...",
        class: "mt-2 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-3 py-2 border" %>
  </div>

  <div class="flex items-center justify-end space-x-3">
    <%= link_to "Cancel", channel_path(channel), class: "inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" %>
    <%= f.submit "Save Changes",
        class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 cursor-pointer" %>
  </div>
<% end %>
