<div class="max-w-2xl mx-auto">
  <div class="flex items-center space-x-3 mb-6">
    <%= link_to "Experts", channels_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    <span class="text-gray-400">/</span>
    <%= link_to @channel.name, channel_path(@channel), class: "text-sm text-gray-500 hover:text-gray-700" %>
    <span class="text-gray-400">/</span>
    <span class="text-sm text-gray-900 font-medium">Edit</span>
  </div>

  <h1 class="text-2xl font-bold text-gray-900 mb-6">Edit Expert Notes</h1>

  <!-- Channel Name (read-only) -->
  <div class="bg-white shadow-sm rounded-lg border border-gray-200 p-6 mb-6">
    <div class="flex items-center space-x-4">
      <% if @channel.thumbnail_url.present? %>
        <img src="<%= @channel.thumbnail_url %>" alt="<%= @channel.name %>"
             class="w-12 h-12 rounded-full object-cover ring-2 ring-gray-100">
      <% else %>
        <div class="w-12 h-12 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center ring-2 ring-gray-100">
          <span class="text-white font-bold text-sm"><%= @channel.name.first(2).upcase %></span>
        </div>
      <% end %>
      <div>
        <p class="text-sm font-medium text-gray-900"><%= @channel.name %></p>
        <p class="text-xs text-gray-500"><%= @channel.video_count %> <%= "video".pluralize(@channel.video_count) %></p>
      </div>
    </div>
  </div>

  <div class="bg-white shadow-sm rounded-lg border border-gray-200 p-6">
    <%= render "channels/form", channel: @channel %>
  </div>
</div>
