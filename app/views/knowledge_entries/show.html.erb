<%
  type_colors = {
    "note" => "bg-blue-50 text-blue-700",
    "article" => "bg-purple-50 text-purple-700",
    "link" => "bg-emerald-50 text-emerald-700",
    "file_upload" => "bg-amber-50 text-amber-700",
    "idea" => "bg-pink-50 text-pink-700"
  }

  type_labels = {
    "note" => "Note",
    "article" => "Article",
    "link" => "Link",
    "file_upload" => "File",
    "idea" => "Idea"
  }
%>

<div class="max-w-3xl mx-auto py-8 space-y-6">
  <!-- Breadcrumb -->
  <nav class="flex items-center space-x-2 text-sm text-gray-500">
    <%= link_to @project.name, project_path(@project), class: "hover:text-gray-700" %>
    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/></svg>
    <span class="text-gray-900 font-medium"><%= @knowledge_entry.title %></span>
  </nav>

  <!-- Header Card -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
    <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
      <div class="flex-1">
        <div class="flex items-center gap-2 mb-2">
          <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-medium <%= type_colors[@knowledge_entry.entry_type] %>">
            <%= type_labels[@knowledge_entry.entry_type] %>
          </span>
          <span class="text-xs text-gray-400"><%= @knowledge_entry.created_at.strftime("%B %d, %Y") %></span>
        </div>
        <h1 class="text-xl font-bold text-gray-900 leading-tight"><%= @knowledge_entry.title %></h1>
      </div>

      <!-- Action Buttons -->
      <div class="flex flex-wrap items-center gap-2">
        <%= link_to edit_project_knowledge_entry_path(@project, @knowledge_entry), class: "inline-flex items-center px-3 py-2 border border-gray-200 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition-colors" do %>
          <svg class="w-4 h-4 mr-1.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
          Edit
        <% end %>

        <%= button_to project_knowledge_entry_path(@project, @knowledge_entry), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this entry?" }, class: "inline-flex items-center px-3 py-2 border border-red-200 text-sm font-medium rounded-lg text-red-600 bg-white hover:bg-red-50 transition-colors" do %>
          <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
          Delete
        <% end %>
      </div>
    </div>
  </div>

  <!-- Source URL (for link type) -->
  <% if @knowledge_entry.link? && @knowledge_entry.source_url.present? %>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
      <div class="flex items-center">
        <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center mr-3">
          <svg class="w-4 h-4 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
        </div>
        <div class="min-w-0 flex-1">
          <p class="text-xs text-gray-500">Source URL</p>
          <%= link_to @knowledge_entry.source_url, @knowledge_entry.source_url, target: "_blank", rel: "noopener noreferrer", class: "text-sm font-medium text-indigo-600 hover:text-indigo-700 truncate block" %>
        </div>
        <svg class="w-4 h-4 text-gray-400 ml-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      </div>
    </div>
  <% end %>

  <!-- File Download (for file_upload type) -->
  <% if @knowledge_entry.file_upload? && @knowledge_entry.file.attached? %>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
      <div class="flex items-center">
        <div class="w-8 h-8 rounded-lg bg-amber-100 flex items-center justify-center mr-3">
          <svg class="w-4 h-4 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-gray-900 truncate"><%= @knowledge_entry.file.filename %></p>
          <p class="text-xs text-gray-500"><%= number_to_human_size(@knowledge_entry.file.byte_size) %></p>
        </div>
        <%= link_to rails_blob_path(@knowledge_entry.file, disposition: "attachment"), class: "inline-flex items-center px-3 py-2 border border-gray-200 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition-colors" do %>
          <svg class="w-4 h-4 mr-1.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          Download
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Body Content -->
  <% if @knowledge_entry.body.present? %>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
      <div class="flex items-center mb-6">
        <div class="w-8 h-8 rounded-lg bg-indigo-100 flex items-center justify-center mr-3">
          <svg class="w-4 h-4 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </div>
        <h2 class="text-lg font-bold text-gray-900">Content</h2>
      </div>
      <div class="prose prose-sm max-w-none text-gray-700">
        <%= simple_format(@knowledge_entry.body) %>
      </div>
    </div>
  <% end %>

  <!-- Summary -->
  <% if @knowledge_entry.summary.present? %>
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
      <div class="flex items-center mb-6">
        <div class="w-8 h-8 rounded-lg bg-gray-100 flex items-center justify-center mr-3">
          <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"/></svg>
        </div>
        <h2 class="text-lg font-bold text-gray-900">Summary</h2>
      </div>
      <div class="prose prose-sm max-w-none text-gray-600">
        <%= simple_format(@knowledge_entry.summary) %>
      </div>
    </div>
  <% end %>

  <!-- Metadata -->
  <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-6">
    <div class="flex flex-wrap gap-x-8 gap-y-3 text-sm text-gray-500">
      <div>
        <span class="font-medium text-gray-700">Created:</span>
        <%= @knowledge_entry.created_at.strftime("%B %d, %Y at %l:%M %p") %>
      </div>
      <% if @knowledge_entry.updated_at != @knowledge_entry.created_at %>
        <div>
          <span class="font-medium text-gray-700">Updated:</span>
          <%= @knowledge_entry.updated_at.strftime("%B %d, %Y at %l:%M %p") %>
        </div>
      <% end %>
      <div>
        <span class="font-medium text-gray-700">Type:</span>
        <%= type_labels[@knowledge_entry.entry_type] %>
      </div>
    </div>
  </div>
</div>
