<%
  entry_types = [
    { key: "note", label: "Note", icon_path: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" },
    { key: "article", label: "Article", icon_path: "M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" },
    { key: "link", label: "Link", icon_path: "M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" },
    { key: "file_upload", label: "File", icon_path: "M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" },
    { key: "idea", label: "Idea", icon_path: "M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" }
  ]

  current_type = knowledge_entry.entry_type || "note"

  body_rows = case current_type
              when "article" then 10
              when "note" then 4
              else 3
              end

  body_label = case current_type
               when "link" then "Notes about this link"
               when "file_upload" then "Notes about this file"
               else "Body"
               end
%>

<div data-controller="entry-type">
  <%= form_with model: [project, knowledge_entry], class: "space-y-6" do |f| %>
    <% if knowledge_entry.errors.any? %>
      <div class="rounded-lg bg-red-50 p-4">
        <ul class="text-sm text-red-700 list-disc list-inside">
          <% knowledge_entry.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= f.hidden_field :entry_type, data: { entry_type_target: "typeField" } %>

    <!-- Entry Type Pills -->
    <div class="flex justify-center">
      <div class="inline-flex items-center bg-gray-100 rounded-xl p-1 gap-1">
        <% entry_types.each do |type| %>
          <button type="button"
            data-action="click->entry-type#selectType"
            data-entry-type="<%= type[:key] %>"
            class="px-4 py-2 rounded-lg text-sm font-medium transition-all
              <%= type[:key] == current_type ? 'bg-white shadow-sm text-indigo-700' : 'text-gray-500 hover:text-gray-700' %>">
            <svg class="w-4 h-4 inline-block mr-1 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= type[:icon_path] %>"/>
            </svg>
            <%= type[:label] %>
          </button>
        <% end %>
      </div>
    </div>

    <!-- Title -->
    <div>
      <%= f.label :title, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :title, placeholder: "Give this entry a title",
          class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-3 py-2 border" %>
    </div>

    <!-- Source URL (link type only) -->
    <div data-entry-type-target="sourceUrlField" class="<%= 'hidden' unless current_type == 'link' %>">
      <%= f.label :source_url, "URL", class: "block text-sm font-medium text-gray-700" %>
      <%= f.url_field :source_url, placeholder: "https://example.com/article",
          class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-3 py-2 border" %>
    </div>

    <!-- File Upload (file_upload type only) -->
    <div data-entry-type-target="fileField" class="<%= 'hidden' unless current_type == 'file_upload' %>">
      <%= f.label :file, class: "block text-sm font-medium text-gray-700" %>
      <%= f.file_field :file,
          class: "mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
      <% if knowledge_entry.file.attached? %>
        <p class="mt-1 text-xs text-gray-500">
          Current file: <%= knowledge_entry.file.filename %>
          (<%= number_to_human_size(knowledge_entry.file.byte_size) %>)
        </p>
      <% end %>
    </div>

    <!-- Body -->
    <div>
      <label for="knowledge_entry_body" class="block text-sm font-medium text-gray-700" data-entry-type-target="bodyLabel"><%= body_label %></label>
      <%= f.text_area :body, rows: body_rows, placeholder: "Write your content here...",
          data: { entry_type_target: "bodyField" },
          class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-3 py-2 border" %>
    </div>

    <!-- Summary (optional) -->
    <div>
      <%= f.label :summary, "Summary (optional)", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :summary, rows: 2, placeholder: "Brief summary of this entry...",
          class: "mt-1 block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm px-3 py-2 border" %>
    </div>

    <!-- Actions -->
    <div class="flex items-center justify-between pt-4 border-t border-gray-100">
      <%= link_to "Cancel", project_path(project),
          class: "inline-flex items-center px-4 py-2 border border-gray-200 text-sm font-medium rounded-lg text-gray-700 bg-white hover:bg-gray-50 transition-colors" %>
      <%= f.submit knowledge_entry.persisted? ? "Save Changes" : "Save Entry",
          class: "inline-flex items-center px-5 py-2.5 border border-transparent text-sm font-medium rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 cursor-pointer transition-colors shadow-sm" %>
    </div>
  <% end %>
</div>
